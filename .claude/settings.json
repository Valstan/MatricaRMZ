{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git pull --ff-only*)",
      "Bash(git stash *)",
      "Bash(git rebase *)",
      "Bash(git push -u origin *)",
      "Bash(git push origin *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh release download *)",
      "Bash(gh release view *)",
      "Bash(gh run watch *)",
      "Bash(git tag *)",
      "Bash(ssh matricarmz *)",
      "Bash(scp * matricarmz:*)",
      "Bash(corepack pnpm *)",
      "Bash(pnpm *)",
      "Bash(node scripts/*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push origin main*)",
      "Bash(git push -u origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push -u origin master*)"
    ]
  },
  "autoMode": {
    "soft_deny": [
      "$defaults",
      "Destructive or irreversible operations on the MatricaRMZ PRODUCTION server (ssh alias `matricarmz`, host a6fd55b8e0ae.vps.myjino.ru): DROP/DELETE/UPDATE/TRUNCATE against the prod PostgreSQL DB, running `db:migrate` or any Drizzle migration on live prod data, `systemctl stop`/`systemctl disable` of the matricarmz-backend services, `rm`/`rm -rf` on prod paths, or `git reset --hard` on the prod checkout. Require explicit same-turn human confirmation before running any of these (brain #025 / GOTCHAS G29 — prior client_settings 76->39 data-loss incident). Read-only prod probes (systemctl is-active, curl /health, git log) stay auto-approved."
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\scripts\\git_sync_check.ps1\" -Warn"
          }
        ]
      }
    ]
  }
}
