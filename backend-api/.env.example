# PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=matricarmz
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGSSL=false

# Backend listener
HOST=127.0.0.1
PORT=3001
TZ=Europe/Moscow
MATRICA_INSTANCE_ROLE=primary

# Security
MATRICA_JWT_SECRET=CHANGE_ME

# Runtime directories
MATRICA_LOGS_DIR=backend-api/logs
MATRICA_UPLOADS_DIR=backend-api/uploads
MATRICA_UPDATES_DIR=backend-api/updates
MATRICA_LEDGER_DIR=backend-api/ledger
MATRICA_LEDGER_DATA_KEY=CHANGE_ME_BASE64

# Public URLs and sync
MATRICA_API_URL=https://a6fd55b8e0ae.vps.myjino.ru
MATRICA_PUBLIC_BASE_URL=https://a6fd55b8e0ae.vps.myjino.ru
SYNC_V2_ENFORCE=1
MATRICA_SYNC_AUTOHEAL_ENABLED=1
MATRICA_SYNC_PULL_ADAPTIVE_ENABLED=1

# Update distribution
MATRICA_TORRENT_TRACKER_PORT=6969
MATRICA_TORRENT_TRACKER_URLS=http://127.0.0.1:6969/announce

# AI and reports
AI_PROFILE=balanced
AI_REPORT_ENABLED=false
AI_REPORT_TZ=Europe/Moscow
# Глобальный рубильник AI. Когда false — ни нейрочат, ни аналитика, ни cron-агент
# логов НЕ обращаются к Anthropic API, /health возвращает features.aiEnabled=false,
# UI скрывает кнопку нейрочата.
AI_ENABLED=true

# Claude API (Anthropic). Получить ключ: https://console.anthropic.com/settings/keys
# Префикс MATRICA_* — основной; ANTHROPIC_API_KEY поддержан как fallback для совместимости со стандартом SDK.
MATRICA_AI_CLAUDE_API_KEY=
# Опциональные оверрайды моделей (по умолчанию: Haiku для chat, Sonnet для analytics)
CLAUDE_MODEL_CHAT=
CLAUDE_MODEL_ANALYTICS=
# Read-only PG user для сбора корпуса чатов в aiAgentChatLearningService
AI_DB_RO_USER=
AI_DB_RO_PASSWORD=
# Read-only tool use (Claude function calling) — БД-tools для нейрочата и аналитики.
AI_CHAT_TOOLS_ENABLED=true
AI_ANALYTICS_TOOLS_ENABLED=true
# Сколько подряд ответов "не знаю" в чате до автоэскалации Haiku → Sonnet
AI_CHAT_ESCALATE_AFTER=3

# История нейрочата: автоудаление сообщений старше N дней.
AI_CHAT_HISTORY_RETENTION_DAYS=90
AI_CHAT_HISTORY_CLEANUP_ENABLED=true

# Cron-агент анализа логов (по умолчанию выключен).
AI_LOG_ANALYSIS_ENABLED=false
AI_LOG_ANALYSIS_TIMES=06:00,18:00
AI_LOG_ANALYSIS_TZ=Europe/Moscow
AI_LOG_ANALYSIS_LOOKBACK_HOURS=12

# Integrations
MATRICA_TELEGRAM_BOT_TOKEN=
MATRICA_TELEGRAM_ALERT_CHAT_ID=
MATRICA_TELEGRAM_ALERT_LOGIN=
YANDEX_DISK_TOKEN=
YANDEX_DISK_BASE_PATH=
MATRICA_LEDGER_RELEASE_TOKEN=
